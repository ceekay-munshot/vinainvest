{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vinainvest",
  "main": "worker.js",
  "compatibility_date": "2026-04-23",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "not_found_handling": "none"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
